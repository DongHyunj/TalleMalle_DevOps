pipeline {
  agent {
    kubernetes {
      label "node-kaniko-${UUID.randomUUID().toString()}"
      namespace "jdh"
      defaultContainer 'node'
      yaml """
apiVersion: v1
kind: Pod
metadata:
  annotations:
    sidecar.istio.io/inject: "false"
spec:
  restartPolicy: Never
  containers:
    - name: node
      image: node:22.17.1-bullseye
      command: ['cat']
      tty: true
    - name: kaniko
      image: gcr.io/kaniko-project/executor:debug
      command: ['/busybox/sh','-c','sleep infinity']
      tty: true
      volumeMounts:
        - name: docker-config
          mountPath: /kaniko/.docker
        - name: workspace
          mountPath: /workspace
    - name: kubectl
      image: bitnami/kubectl:latest
      command: ['sleep', 'infinity']
      tty: true
      securityContext:
        runAsUser: 0
  volumes:
    - name: workspace
      emptyDir: {}
    - name: docker-config
      secret:
        secretName: dockerhub-cred1
        items:
          - key: .dockerconfigjson
            path: config.json
"""
    }
  }

  environment {
    IMAGE_NAME     = 'deatytim/tmfront'
    IMAGE_TAG      = "${env.BUILD_NUMBER}"
    NAMESPACE      = 'jdh'
    SVC_NAME       = 'frontend-service'
    CONTAINER_NAME = 'frontend'
  }

  stages {
    stage('Checkout') {
      steps {
        container('node') {
          checkout scm
        }
      }
    }



    stage('Setup K8s Resources') {
      steps {
        container('kubectl') {
          sh '''
            # DeploymentмЩА IngressлКФ нХ≠мГБ apply (мЭілѓЄмІА/мК§нОЩ лПЩкЄ∞нЩФ, slot selectorмЧР мШБнЦ• мЧЖмЭМ)
            kubectl apply -f - <<EOF
apiVersion: apps/v1
kind: Deployment
metadata:
  name: frontend-blue-deployment
  namespace: jdh
  labels:
    type: frontend
    slot: blue
spec:
  replicas: 1
  selector:
    matchLabels:
      type: frontend
      slot: blue
  template:
    metadata:
      labels:
        type: frontend
        slot: blue
    spec:
      containers:
        - name: frontend
          image: deatytim/tmfront:latest
          imagePullPolicy: Always
          ports:
            - containerPort: 80
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: frontend-green-deployment
  namespace: jdh
  labels:
    type: frontend
    slot: green
spec:
  replicas: 1
  selector:
    matchLabels:
      type: frontend
      slot: green
  template:
    metadata:
      labels:
        type: frontend
        slot: green
    spec:
      containers:
        - name: frontend
          image: deatytim/tmfront:latest
          imagePullPolicy: Always
          ports:
            - containerPort: 80
---
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: frontend-ingress
  namespace: jdh
  annotations:
    nginx.ingress.kubernetes.io/ssl-redirect: "true"
    nginx.ingress.kubernetes.io/use-regex: "true"
spec:
  ingressClassName: nginx
  tls:
    - hosts:
        - www.tallemalletest.kro.kr
      secretName: tallemalle-tls
  rules:
    - host: www.tallemalletest.kro.kr
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: frontend-service
                port:
                  number: 80
EOF

            # ServiceлКФ мЭілѓЄ м°імЮђнХШл©і slot selectorл•Љ мЬ†мІАнХШк≥†, мЧЖмЭД лХМлІМ мГЭмД±
            if kubectl get svc frontend-service -n jdh > /dev/null 2>&1; then
              echo "frontend-service мЭілѓЄ м°імЮђ вАФ slot selector мЬ†мІА"
            else
              echo "frontend-service мЧЖмЭМ вАФ slot: blue л°Ь міИкЄ∞ мГЭмД±"
              kubectl apply -f - <<EOF
apiVersion: v1
kind: Service
metadata:
  name: frontend-service
  namespace: jdh
spec:
  selector:
    type: frontend
    slot: blue
  ports:
    - port: 80
      targetPort: 80
EOF
            fi
          '''
        }
      }
    }

    stage('npm Install & Build') {
      steps {
        container('node') {
          withCredentials([file(credentialsId: 'jdh-front.env', variable: 'ENV_FILE')]) {
            sh 'cp $ENV_FILE frontend/.env'
          }
          dir('frontend') {
            sh '''
              npm install
              npm run build
            '''
          }
        }
      }
    }

    stage('Kaniko Build & Push') {
      steps {
        container('kaniko') {
          sh """
            /kaniko/executor \\
              --context=${WORKSPACE}/frontend \\
              --dockerfile=${WORKSPACE}/frontend/Dockerfile \\
              --destination=${IMAGE_NAME}:${IMAGE_TAG} \\
              --destination=${IMAGE_NAME}:latest \\
              --single-snapshot \\
              --use-new-run \\
              --cache=true \\
              --snapshotMode=redo
          """
        }
      }
    }

    stage('Blue/Green Deploy') {
      steps {
        container('kubectl') {
          script {
            // нШДмЮђ мДЬлєДмК§к∞А к∞Ал¶ђнВ§лКФ slot нЩХмЭЄ
            def activeSlot = sh(
              script: "kubectl get svc ${SVC_NAME} -n ${NAMESPACE} -o jsonpath='{.spec.selector.slot}'",
              returnStdout: true
            ).trim()

            // activeк∞А blueл©і greenмЧР л∞∞нПђ, greenмЭіл©і blueмЧР л∞∞нПђ
            def newSlot   = (activeSlot == 'blue') ? 'green' : 'blue'
            def newDeploy = "frontend-${newSlot}-deployment"

            echo "нШДмЮђ active slot: ${activeSlot} вЖТ л∞∞нПђ лМАмГБ: ${newSlot}"

            // inactive deploymentмЧР мГИ мЭілѓЄмІА л∞∞нПђ л∞П л°§мХДмЫГ лМАкЄ∞
            sh """
              kubectl set image deployment/${newDeploy} \\
                ${CONTAINER_NAME}=${IMAGE_NAME}:${IMAGE_TAG} \\
                -n ${NAMESPACE}

              kubectl rollout status deployment/${newDeploy} \\
                -n ${NAMESPACE} --timeout=180s
            """

            // л°§мХДмЫГ мД±к≥µ вЖТ мДЬлєДмК§ нКЄлЮШнФљмЭД мГИ slotмЬЉл°Ь м†ДнЩШ
            sh """
              kubectl patch svc ${SVC_NAME} -n ${NAMESPACE} \\
                -p '{"spec":{"selector":{"type":"frontend","slot":"${newSlot}"}}}'
            """

            echo "Blue/Green м†ДнЩШ мЩДл£М: ${activeSlot} вЖТ ${newSlot}"
          }
        }
      }
    }
  }

  post {
    success {
      echo "Frontend л∞∞нПђ мЩДл£М: ${IMAGE_NAME}:${IMAGE_TAG}"
    }
    failure {
      echo "Frontend л∞∞нПђ мЛ§нМ® вАФ мДЬлєДмК§лКФ кЄ∞м°і slot мЬ†мІА"
    }
  }
}
