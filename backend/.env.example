# Database Configuration (데이터베이스 설정)
DB_URL=jdbc:mariadb://db:3306/tallemalle # DB 접속 URL
DB_USER=root                             # DB 사용자명
DB_PASS=your_secure_password             # DB 비밀번호

# JWT Configuration (JWT 보안 설정)
JWT_SECRET=your_jwt_secret_key           # JWT 서명용 비밀키
JWT_EXPIRE=86400                         # JWT 만료 시간 (초 단위)

# Project Configuration (프로젝트 설정)
UPLOAD_PATH=./uploads                    # 파일 업로드 경로
TOSS_SECRET_KEY=your_toss_secret_key     # 토스페이먼츠 시크릿 키
AES_KEY=your_aes_encryption_key          # AES 암호화 키 (데이터 보호용)

# App Settings (앱 주소 설정)
COOKIE_DOMAIN=localhost                  # 쿠키 도메인 (배포 시 도메인 주소로 변경)
FRONT_URL=http://localhost               # 프론트엔드 접속 주소
API_URL=http://localhost:8080            # 백엔드 API 접속 주소

# SSL Settings (SSL 인증서 설정)
SSL_KEY_PASS=your_ssl_password           # SSL 키스토어 비밀번호

# OAuth2 Configuration (소셜 로그인 설정)
GOOGLE_CLIENT_ID=your_google_client_id           # 구글 클라이언트 ID
GOOGLE_CLIENT_SECRET=your_google_client_secret   # 구글 클라이언트 시크릿
GOOGLE_REDIRECT_URI=http://localhost:8080/login/oauth2/code/google # 구글 리다이렉트 URI

KAKAO_CLIENT_ID=your_kakao_client_id             # 카카오 클라이언트 ID (REST API 키)
KAKAO_CLIENT_SECRET=your_kakao_client_secret     # 카카오 클라이언트 시크릿
KAKAO_REDIRECT_URI=http://localhost:8080/login/oauth2/code/kakao   # 카카오 리다이렉트 URI

# Mail Configuration (메일 전송 설정)
MAIL_ADDR=your_email@gmail.com           # 관리자 메일 주소 (Gmail 권장)
MAIL_PASS=your_email_password            # 메일 앱 비밀번호

# AWS Configuration (AWS S3 설정)
AWS_ACCESS_KEY=your_aws_access_key       # AWS 액세스 키
AWS_SECRET_KEY=your_aws_secret_key       # AWS 시크릿 키

# External APIs (외부 API 키)
KAKAO_API_KEY=your_kakao_api_key         # 카카오 API 키 (REST API)
PORTONE_SECRET_API=your_portone_secret_api # 포트원 시크릿 API 키

# Web Push (VAPID) (웹 푸시 알림 설정)
VAPID_PUBLIC_KEY=your_vapid_public_key   # VAPID 공개키
VAPID_PRIVATE_KEY=your_vapid_private_key # VAPID 개인키
