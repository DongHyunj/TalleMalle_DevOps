# Frontend API Configuration (프론트엔드 API 설정)
VITE_API_BASE_URL=http://localhost:8080  # 백엔드 API 서버 주소
VITE_WS_URL=ws://localhost:8080/ws       # 웹소켓 접속 주소

# External API Keys (외부 서비스 API 키)
VITE_KAKAO_MAP_KEY=your_kakao_map_javascript_key # 카카오맵 자바스크립트 키
VITE_PORTONE_STORE_ID=your_portone_store_id      # 포트원 가맹점 식별코드
VITE_PORTONE_CHANNEL_KEY=your_portone_channel_key # 포트원 채널 키

# Web Push (VAPID) (웹 푸시 알림 설정)
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key      # VAPID 공개키 (백엔드 설정과 동일해야 함)
